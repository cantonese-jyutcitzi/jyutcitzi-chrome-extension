{
  "manifest_version": 3,
  "name": "Jyutcitzi",
  "version": "1.2.1",
  "description": "Type Jyutping keys from jyutcitzi-RIME dictionaries; inserts web or font Jyutcitzi output in text fields.",
  "permissions": ["storage"],
  "action": {
    "default_title": "Jyutcitzi",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "vendor/js-yaml.min.js",
        "trie.js",
        "parser.js",
        "content.js"
      ],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["yaml/*", "fonts/*.ttf"],
      "matches": ["<all_urls>"]
    }
  ]
}
